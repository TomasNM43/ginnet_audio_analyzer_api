<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified" />
    </handlers>
    <httpPlatform processPath="C:\inetpub\wwwroot\ginnet_audio_analyzer_api\venv\Scripts\python.exe"
                  arguments="-m uvicorn main:app --host 127.0.0.1 --port %HTTP_PLATFORM_PORT% --workers 2"
                  stdoutLogEnabled="true"
                  stdoutLogFile="C:\inetpub\wwwroot\ginnet_audio_analyzer_api\logs\uvicorn.log"
                  startupTimeLimit="120"
                  requestTimeout="00:04:00">
      <environmentVariables>
        <environmentVariable name="PORT" value="%HTTP_PLATFORM_PORT%" />
        <environmentVariable name="PYTHONPATH" value="C:\inetpub\wwwroot\ginnet_audio_analyzer_api" />
      </environmentVariables>
    </httpPlatform>
  </system.webServer>
</configuration>
